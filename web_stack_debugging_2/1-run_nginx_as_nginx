#!/usr/bin/env bash
# Configures nginx to run as nginx user listening on port 8080

# Ensure nginx user exists
id nginx || useradd --system --no-create-home --shell /bin/false nginx

# Set user directive in nginx.conf
sed -i 's/^user .*/user nginx;/' /etc/nginx/nginx.conf
grep -q "^user nginx;" /etc/nginx/nginx.conf || sed -i '1s/^/user nginx;\n/' /etc/nginx/nginx.conf

# Set port to 8080
sed -i 's/listen 80 default_server;/listen 8080 default_server;/' /etc/nginx/sites-available/default
sed -i 's/listen \[::\]:80 default_server;/listen [::]:8080 default_server;/' /etc/nginx/sites-available/default

# Fix ownership
chown -R nginx:nginx /var/log/nginx
chown -R nginx:nginx /var/lib/nginx

# Validate and restart nginx
nginx -t && service nginx restart
